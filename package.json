{
  "name": "typespec-schema-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:updates": "pnpm outdated --recursive --long",
    "check:lefthook": "pnpm format",
    "build": "pnpm run format && run-s \"build:*\"",
    "build:foo-backend": "tsp compile src/foo-backend",
    "build:hoge-backend": "tsp compile src/hoge-backend",
    "format": "tsp format .",
    "prepare": "lefthook install",
    "preview": "echo 'Swagger UI: http://localhost:8080' && docker compose up"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@typespec/compiler": "^1.12.0",
    "@typespec/http": "^1.12.0",
    "@typespec/openapi": "^1.12.0",
    "@typespec/openapi3": "^1.12.0",
    "@typespec/rest": "^0.82.0",
    "@typespec/versioning": "^0.82.0",
    "lefthook": "^2.1.9",
    "npm-run-all2": "^9.0.1"
  }
}
